{
  "apiVersion": "run.googleapis.com/v1",
  "kind": "Job",
  "metadata": {"name": "olw-pipeline"},
  "spec": {
    "template": {
      "spec": {
        "template": {
          "spec": {
            "containers": [{
              "image": "asia-east1-docker.pkg.dev/llm-wiki-cloud/cloud-run-images/olw-pipeline:latest",
              "env": [
                {"name": "BUCKET", "value": "llm-wiki-data"},
                {"name": "DATA_DIR", "value": "/data"},
                {"name": "WORKSPACE", "value": "prod"},
                {"name": "VAULT_PATH", "value": "/vault"},
                {"name": "WORKSPACE_DIR", "value": "/workspace"},
                {"name": "LLM_API_KEY", "valueFrom": {"secretKeyRef": {"name": "llm-api", "key": "token"}}},
                {"name": "DEEPSEEK_API_KEY", "valueFrom": {"secretKeyRef": {"name": "deepseek", "key": "token"}}},
                {"name": "USER_ID", "value": "legacy-user"},
                {"name": "PROJECT_ID", "value": "legacy-project"},
                {"name": "TASK_TYPE", "value": "build"},
                {"name": "UNRELATED", "value": "must-not-enter-rollback-artifact"}
              ],
              "args": ["run", "[[\"run\",\"--auto-approve\"]]"],
              "volumeMounts": [{"name": "gcs", "mountPath": "/data"}]
            }],
            "volumes": [{"name": "gcs", "csi": {"driver": "gcsfuse.run.googleapis.com"}}]
          }
        }
      }
    }
  },
  "status": {}
}
