{
  "apiVersion": "run.googleapis.com/v1",
  "kind": "Job",
  "metadata": {"name": "olw-pipeline"},
  "spec": {
    "template": {
      "spec": {
        "template": {
          "spec": {
            "containers": [{
              "image": "asia-east1-docker.pkg.dev/llm-wiki-cloud/cloud-run-images/olw-pipeline:latest",
              "env": [
                {"name": "BUCKET", "value": "llm-wiki-data-second"},
                {"name": "DATA_DIR", "value": "/second"}
              ],
              "args": ["run", "[[\"run\",\"--auto-approve\"]]"],
              "volumeMounts": [{"name": "second", "mountPath": "/second"}]
            }],
            "volumes": [{
              "name": "second",
              "csi": {
                "driver": "gcsfuse.run.googleapis.com",
                "volumeAttributes": {
                  "bucketName": "rollback-bucket",
                  "gcsfuseVersion": "v2"
                }
              }
            }]
          }
        }
      }
    }
  }
}
